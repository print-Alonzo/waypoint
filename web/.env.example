# Which city dataset to build (data/<slug>/). Defaults to metro-manila.
NEXT_PUBLIC_CITY=metro-manila

# A Mapbox public access token — enables real road routes + road-based
# travel times on the result map. Without it, the app falls back to straight
# lines and haversine-estimated times (see README "Road routing"). Public/
# client-side token by design; restrict it by URL in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=

# MongoDB Atlas connection string + database name for the willingness-to-pay
# validation funnel (app/api/validation/route.ts). Server-only — do NOT prefix
# with NEXT_PUBLIC_. Leave unset to disable capture (the route returns 503);
# set the `validation` flag in lib/features.ts to false to hide the funnel's UI
# entirely once the study ends.
MONGODB_URI=
MONGODB_DB=waypoint_validation
