# Which city dataset to build (data/<slug>/). Defaults to metro-manila.
NEXT_PUBLIC_CITY=metro-manila

# A Mapbox public access token — enables real road routes + road-based
# travel times on the result map. Without it, the app falls back to straight
# lines and haversine-estimated times (see README "Road routing"). Public/
# client-side token by design; restrict it by URL in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=
